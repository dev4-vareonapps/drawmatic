# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB (Docker Compose: mongodb://mongodb:27017/drawmatic; local dev: mongodb://localhost:27017/drawmatic)
MONGODB_URI=mongodb://mongodb:27017/drawmatic
DATABASE_NAME=drawmatic

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-secure-random-string
NEXTAUTH_URL=http://localhost:3000

# Docker dev portal: http://localhost:8081
# Mongo Express (no login popup in local Docker): http://localhost:8082
